# Deployer wallet private key (for contract deployment only)
PRIVATE_KEY=your_deployer_private_key_here

# Relayer private key - THIS WALLET PAYS ALL GAS FEES FOR USERS
# Users create tenders and vote for FREE, this wallet covers the cost
VITE_RELAYER_PRIVATE_KEY=your_relayer_private_key_here

# Etherscan API key for contract verification
POLYGONSCAN_API_KEY=your_etherscan_api_key_here

# Pinata IPFS credentials for file storage
# Get from: https://app.pinata.cloud/developers/api-keys
VITE_PINATA_JWT=your_pinata_jwt_here
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# Gemini AI API key for description enhancement and file parsing
# Model: gemini-2.0-flash-exp
VITE_GEMINI_API_KEY=
